{
    admin off
    auto_https disable_redirects
    servers {
        protocols h1 h2
    }
}

https://vaultmind.internal:8443 {
    tls internal
    encode zstd gzip
    reverse_proxy api:8080

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        -Server
        -Via
    }
}

http://127.0.0.1:8081 {
    reverse_proxy api:8080
}
